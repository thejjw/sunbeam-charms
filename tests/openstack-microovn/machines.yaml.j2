machines:
  "0":
    base: ubuntu@24.04
    arch: amd64

applications:
  microceph:
    charm: ch:microceph
    channel: squid/stable
    base: ubuntu@24.04
    arch: amd64
    to:
      - "0"
    scale: 1
    options:
      snap-channel: squid/stable
      default-pool-size: 1
      enable-rgw: "*"
    storage:
      osd-standalone: loop,3,2G
  sunbeam-machine:
    {% if sunbeam_machine is defined and sunbeam_machine is sameas true -%}
    charm: ../../../sunbeam-machine.charm
    {% else -%}
    charm: ch:sunbeam-machine
    channel: 2026.1/edge
    {% endif -%}
    scale: 1
    to:
      - "0"
  epa-orchestrator:
    {% if epa_orchestrator is defined and epa_orchestrator is sameas true -%}
    charm: ../../../epa-orchestrator.charm
    {% else -%}
    charm: ch:epa-orchestrator
    channel: 2026.1/edge
    {% endif -%}
    base: ubuntu@24.04
  cinder-volume:
    {% if cinder_volume is defined and cinder_volume is sameas true -%}
    charm: ../../../cinder-volume.charm
    {% else -%}
    charm: ch:cinder-volume
    channel: 2026.1/edge
    {% endif -%}
    scale: 1
    to:
      - "0"
    options:
      snap-channel: 2026.1/edge
  cinder-microceph:
    {% if cinder_volume_ceph is defined and cinder_volume_ceph is sameas true -%}
    charm: ../../../cinder-volume-ceph.charm
    {% else -%}
    charm: ch:cinder-volume-ceph
    channel: 2026.1/edge
    {% endif -%}
    options:
      ceph-osd-replication-count: 1
  hypervisor:
    {% if openstack_hypervisor is defined and openstack_hypervisor is sameas true -%}
    charm: ../../../openstack-hypervisor.charm
    {% else -%}
    charm: ch:openstack-hypervisor
    channel: 2026.1/edge
    {% endif -%}
    scale: 1
    to:
      - "0"
    arch: amd64
    options:
      snap-channel: 2026.1/edge
      external-bridge-address: 0.0.0.0/0
      ovs-provider: microovn
  manila-data:
    {% if manila_data is defined and manila_data is sameas true -%}
    charm: ../../../manila-data.charm
    {% else -%}
    charm: ch:manila-data
    channel: 2026.1/edge
    {% endif -%}
    scale: 1
    to:
      - "0"
    arch: amd64
    options:
      snap-channel: 2026.1/edge
  microovn:
    charm: ch:microovn
    channel: 25.03/stable
    base: ubuntu@24.04
    scale: 1
    to:
      - "0"
  microcluster-token-distributor:
    charm: ch:microcluster-token-distributor
    channel: v1/stable
    base: ubuntu@24.04
    scale: 1
    to:
      - "0"
  sunbeam-ovn-proxy:
    {% if sunbeam_ovn_proxy is defined and sunbeam_ovn_proxy is sameas true -%}
    charm: ../../../sunbeam-ovn-proxy.charm
    {% else -%}
    charm: ch:sunbeam-ovn-proxy
    channel: 2026.1/edge
    {% endif -%}
    base: ubuntu@24.04
    scale: 1
    to:
      - "0"
  openstack-network-agents:
    {% if openstack_network_agents is defined and openstack_network_agents is sameas true -%}
    charm: ../../../openstack-network-agents.charm
    {% else -%}
    charm: ch:openstack-network-agents
    channel: 2026.1/edge
    {% endif -%}
    base: ubuntu@24.04
    options:
      snap-channel: 2026.1/edge
      external-bridge-address: 0.0.0.0/0

saas:
  amqp:
    url: admin/K8S_MODEL.amqp
  identity-credentials:
    url: admin/K8S_MODEL.identity-credentials
  cinder-database:
    url: admin/K8S_MODEL.cinder-database
  manila-database:
    url: admin/K8S_MODEL.manila-database
  send-ca-cert:
    url: admin/K8S_MODEL.send-ca-cert
  certificates:
    url: admin/K8S_MODEL.certificates
  nova-service:
    url: admin/K8S_MODEL.nova-service
  traefik-route-rgw:
    url: admin/K8S_MODEL.traefik-route-rgw
  identity-service:
    url: admin/K8S_MODEL.identity-service
  barbican-service:
    url: admin/K8S_MODEL.barbican-service

relations:
  - - sunbeam-machine:sunbeam-machine
    - epa-orchestrator:sunbeam-machine

  - - cinder-volume:amqp
    - amqp:amqp
  - - cinder-volume:identity-credentials
    - identity-credentials:identity-credentials
  - - cinder-volume:database
    - cinder-database
  - - cinder-volume:receive-ca-cert
    - send-ca-cert:send-ca-cert

  - - microceph:ceph
    - cinder-microceph:ceph
  - - cinder-volume:cinder-volume
    - cinder-microceph:cinder-volume

  - - microceph:receive-ca-cert
    - send-ca-cert:send-ca-cert
  - - microceph:traefik-route-rgw
    - traefik-route-rgw:traefik-route
  - - microceph:identity-service
    - identity-service:identity-service

  - - amqp:amqp
    - hypervisor:amqp
  - - identity-credentials:identity-credentials
    - hypervisor:identity-credentials
  - - send-ca-cert:send-ca-cert
    - hypervisor:receive-ca-cert
  - - sunbeam-ovn-proxy:ovsdb-cms
    - hypervisor:ovsdb-cms
  - - certificates
    - hypervisor:certificates
  - - nova-service
    - hypervisor:nova-service
  - - barbican-service
    - hypervisor:barbican-service
  - - hypervisor:ceph-access
    - cinder-microceph:ceph-access

  - - amqp:amqp
    - manila-data:amqp
  - - identity-credentials:identity-credentials
    - manila-data:identity-credentials
  - - manila-data:database
    - manila-database

  - - microovn:cluster
    - microcluster-token-distributor:microcluster-cluster
  - - certificates
    - microovn:certificates
  - - microovn:ovsdb
    - sunbeam-ovn-proxy:ovsdb
  - - microovn:juju-info
    - openstack-network-agents:juju-info

---
applications:
  cinder-volume:
    offers:
      storage-backend:
        endpoints:
          - storage-backend
  microceph:
    offers:
      ceph:
        endpoints:
          - ceph
      ceph-nfs:
        endpoints:
          - ceph-nfs
  sunbeam-ovn-proxy:
    offers:
      sunbeam-ovn-proxy:
        endpoints:
          - ovsdb-cms
