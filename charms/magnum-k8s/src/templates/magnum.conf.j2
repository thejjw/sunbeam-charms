[DEFAULT]
debug = {{ options.debug }}
lock_path = /var/lock/magnum
state_path = /var/lib/magnum

transport_url = {{ amqp.transport_url }}

{% include "parts/section-database" %}

{% include "parts/section-identity" %}
region_name = {{ options.region }}

[keystone_auth]
auth_section = keystone_authtoken

{% include "parts/section-service-user" %}

{% include "parts/section-trust" %}

[oslo_messaging_notifications]
driver = messagingv2

# Update region name from relations

[cinder_client]
{% set client_region = options.region -%}
{% set client_endpoint_value = "adminURL" -%}
{% set client_ca_key = "ca_file" -%}
{% include "parts/client-endpoint-type-admin" %}

[api]
api_paste_config=/etc/magnum/api-paste.ini
workers = 4

[conductor]
workers = 4

{% include "parts/section-oslo-middleware" %}

{% include "parts/section-oslo-messaging-rabbit" %}

[glance_client]
{% set client_region = options.region -%}
{% set client_endpoint_value = "adminURL" -%}
{% set client_ca_key = "ca_file" -%}
{% include "parts/client-endpoint-type-admin" %}

[heat_client]
{% set client_region = options.region -%}
{% set client_endpoint_value = "adminURL" -%}
{% set client_ca_key = "ca_file" -%}
{% include "parts/client-endpoint-type-admin" %}

[neutron_client]
{% set client_region = options.region -%}
{% set client_endpoint_value = "adminURL" -%}
{% set client_ca_key = "ca_file" -%}
{% include "parts/client-endpoint-type-admin" %}

[nova_client]
{% set client_region = options.region -%}
{% set client_endpoint_value = "adminURL" -%}
{% set client_ca_key = "ca_file" -%}
{% include "parts/client-endpoint-type-admin" %}

[octavia_client]
{% set client_region = options.region -%}
{% set client_endpoint_value = "adminURL" -%}
{% set client_ca_key = "ca_file" -%}
{% include "parts/client-endpoint-type-admin" %}

[audit_middleware_notifications]
driver = log

{% if receive_ca_cert and receive_ca_cert.ca_bundle -%}
[drivers]
openstack_ca_file = /usr/local/share/ca-certificates/ca-bundle.pem
{% endif -%}

[cluster_template]
kubernetes_allowed_network_drivers = {{ options.allowed_network_drivers }}

[capi_helm]
kubeconfig_file = /etc/magnum/kubeconfig
helm_chart_repo = {{ options.helm_chart_repo }}
helm_chart_name = {{ options.helm_chart_name }}
default_helm_chart_version = 0.1.0
api_resources = {{ options.capi_api_resources }}
k8s_control_plane_resource_conditions = MachinesReady,Ready,ControlPlaneComponentsHealthy
