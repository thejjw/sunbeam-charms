###############################################################################
# [ WARNING ]
# cloudkitty configuration file maintained by Juju
# local changes may be overwritten.
###############################################################################
[DEFAULT]
debug = {{ options.debug }}
transport_url = {{ amqp.transport_url }}
auth_strategy = keystone

{% include "parts/section-database" %}

{% include "parts/section-identity" %}

{% include "parts/section-service-user" %}

[oslo_concurrency]
lock_path = /var/lib/cloudkitty/tmp

{% include "parts/section-oslo-messaging-rabbit" %}

[audit_middleware_notifications]
driver = log

[storage]
version = 2
backend = loki

[storage_loki]
# Pull variables straight from the native relation handler namespace key block!
{% if logging and logging.logging_endpoints -%}
url = {{ logging.logging_endpoints }}
{% else -%}
url = http://localhost:3100/loki/api/v1
{% endif -%}

{% if receive_ca_cert and receive_ca_cert.ca_bundle -%}
ca_file = /usr/local/share/ca-certificates/ca-bundle.pem
insecure = false
{% else -%}
insecure = true
{% endif -%}

[fetcher]
backend = gnocchi

[fetcher_gnocchi]
gnocchi_auth_type = keystone
auth_section = keystone_authtoken
{% set client_region = options.region -%}
{% include "parts/client-interface-admin" %}

[collect]
collector = gnocchi

[collector_gnocchi]
auth_section = keystone_authtoken
{% set client_region = options.region -%}
{% include "parts/client-interface-admin" %}
