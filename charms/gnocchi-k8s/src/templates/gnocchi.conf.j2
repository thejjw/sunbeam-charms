[DEFAULT]
debug = {{ options.debug }}
api_paste_confg = /etc/gnocchi/api-paste.ini

[api]
auth_mode = keystone

[indexer]
{% if database.connection -%}
url = {{ database.connection }}
{% endif -%}


[storage]
{% if s3_credentials is defined %}
driver = s3
s3_endpoint_url = {{ s3_credentials.s3_endpoint }}
s3_access_key_id = {{ s3_credentials.s3_access_key_id }}
s3_secret_access_key = {{ s3_credentials.s3_secret_access_key }}
s3_bucket_prefix = {{ s3_credentials.s3_bucket }}
s3_region_name = {{ s3_credentials.s3_region }}
{% else %}
driver = ceph
ceph_pool = gnocchi
ceph_username = gnocchi
ceph_conffile = /etc/ceph/ceph.conf
{% endif %}

[metricd]
workers = 4

{% include "parts/section-identity" %}

{% include "parts/section-oslo-middleware" %}

[audit_middleware_notifications]
driver = log
