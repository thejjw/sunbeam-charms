[DEFAULT]
debug = {{ options.debug }}

{% if amqp -%}
transport_url = {{ amqp.transport_url }}
{% endif -%}

[api_settings]
{% if ovn -%}
{% if options.amphora_network_attachment -%}
enabled_provider_drivers = amphora:The Octavia Amphora driver,ovn:Octavia OVN driver
{% else -%}
enabled_provider_drivers = ovn:Octavia OVN driver
{% endif -%}
default_provider_driver = ovn
{% else -%}
enabled_provider_drivers = amphora:The Octavia Amphora driver
default_provider_driver = amphora
{%- endif %}

[driver_agent]
{% if ovn -%}
enabled_provider_agents = ovn
{%- endif %}

[ovn]
{% if ovn -%}
ovn_nb_connection = {{ ovsdb_cms.db_nb_connection_strs }}
ovn_nb_private_key = {{ ovn.ovn_key }}
ovn_nb_certificate = {{ ovn.ovn_cert }}
ovn_nb_ca_cert = {{ ovn.ovn_ca_cert }}

ovn_sb_connection = {{ ovsdb_cms.db_sb_connection_strs }}
ovn_sb_private_key = {{ ovn.ovn_key }}
ovn_sb_certificate = {{ ovn.ovn_cert }}
ovn_sb_ca_cert = {{ ovn.ovn_ca_cert }}
{%- endif %}

{% include "parts/section-database" %}

[service_auth]
{% include "parts/identity-data" %}

{% include "parts/section-identity" %}

[audit]
enabled = True
audit_map_file = /etc/octavia/api_audit_map.conf

[audit_middleware_notifications]
driver = log

[controller_worker]
{% if options.amp_ssh_key_name -%}
amp_ssh_key_name = {{ options.amp_ssh_key_name }}
{% endif -%}
{% if options.amp_image_owner_id -%}
amp_image_owner_id = {{ options.amp_image_owner_id }}
{% endif -%}
{% if options.amp_secgroup_list -%}
amp_secgroup_list = {{ options.amp_secgroup_list }}
{% endif -%}
{% if options.amp_flavor_id -%}
amp_flavor_id = {{ options.amp_flavor_id }}
{% endif -%}
{% if options.amp_boot_network_list -%}
amp_boot_network_list = {{ options.amp_boot_network_list }}
{% endif -%}
{% if options.amp_image_tag -%}
amp_image_tag = {{ options.amp_image_tag }}
{% endif -%}
amp_active_retries = 180
{% if options.lb_mgmt_controller_cacert -%}
# This certificate is installed on the Amphorae and used for validating
# the authenticity of the Octavia controller.
client_ca = /etc/octavia/certs/controller_ca.pem
{% endif -%}
network_driver = allowed_address_pairs_driver
compute_driver = compute_nova_driver
amphora_driver = amphora_haproxy_rest_driver
loadbalancer_topology = {{ options.loadbalancer_topology }}
{% if options.enable_volume_based_amphora -%}
volume_driver = volume_cinder_driver
{% endif %}

[nova]
{% if options.region -%}
region_name = {{ options.region }}
{% endif -%}
{%- if options.loadbalancer_topology == "SINGLE" or options.anti_affinity_policy == "disable" %}
enable_anti_affinity = False
{%- elif options.loadbalancer_topology == "ACTIVE_STANDBY" %}
{%- if options.anti_affinity_policy == "auto" %}
enable_anti_affinity = True
anti_affinity_policy = soft-anti-affinity
{%- elif options.anti_affinity_policy in ["anti-affinity", "soft-anti-affinity"] %}
enable_anti_affinity = True
anti_affinity_policy = {{ options.anti_affinity_policy }}
{%- endif %}
{%- endif %}

[cinder]
{% if options.region -%}
region_name = {{ options.region }}
{% endif -%}
{% if options.enable_volume_based_amphora -%}
volume_size = {{ options.volume_size }}
{% if options.volume_type -%}
volume_type = {{ options.volume_type }}
{% endif -%}
{% endif %}

[certificates]
# Certificates for authentication between Octavia controllers
# and its Amphorae instances are issued locally on the Octavia controller.
# Note that these certificates are not used for any load balancer payload data
cert_generator = local_cert_generator
{% if options.lb_mgmt_issuing_cacert -%}
# This certificate is used to issue individual certificates for each
# Amphora and to validate their authenticity when they connect to the
# Octavia controller.
ca_certificate = /etc/octavia/certs/issuing_ca.pem
{% endif -%}
{% if options.lb_mgmt_issuing_ca_private_key -%}
ca_private_key = /etc/octavia/certs/issuing_ca_key.pem
{% endif -%}
{% if options.lb_mgmt_issuing_ca_key_passphrase -%}
ca_private_key_passphrase = {{ options.lb_mgmt_issuing_ca_key_passphrase }}
{% endif -%}
{% if barbican_service and barbican_service.service_ready -%}
cert_manager = barbican_cert_manager
{% endif -%}
{% if options.region -%}
region_name = {{ options.region }}
{% endif %}

[haproxy_amphora]
{% if options.lb_mgmt_issuing_cacert -%}
# This certificate is used by the Octavia controller to validate the
# authenticity of the Amphorae connecting to it.
server_ca = /etc/octavia/certs/issuing_ca.pem
{% endif -%}
{% if options.lb_mgmt_controller_cert -%}
# This certificate is used by the Octavia controller when it takes on the
# role as a "client" connecting to the Amphorae.
client_cert = /etc/octavia/certs/controller_cert.pem
{% endif -%}
connection_max_retries = {{ options.connection_max_retries }}
connection_retry_interval = {{ options.connection_retry_interval }}
active_connection_max_retries = {{ options.active_connection_max_retries }}
active_connection_retry_interval = {{ options.active_connection_retry_interval }}
{% if options.user_log_format -%}
user_log_format = {{ options.user_log_format }}
{% endif -%}
{% if not options.connection_logging -%}
connection_logging = False
{% endif -%}

{% include "parts/section-oslo-messaging-rabbit" %}

{% include "parts/section-oslo-notifications" %}

[oslo_messaging]
topic = octavia

{% if amphora_health.bind_ip or amphora_health.heartbeat_key -%}
[health_manager]
{% if amphora_health.bind_ip -%}
bind_ip = {{ amphora_health.bind_ip }}
{% endif -%}
{% if amphora_health.controller_ip_port_list -%}
controller_ip_port_list = {{ amphora_health.controller_ip_port_list }}
{% endif -%}
{% if amphora_health.heartbeat_key -%}
heartbeat_key = {{ amphora_health.heartbeat_key }}
{% endif -%}
{% endif -%}

[amphora_agent]
{% if options.admin_log_targets -%}
admin_log_targets = {{ options.admin_log_targets }}
administrative_log_facility = {{ options.administrative_log_facility }}
{% endif -%}
{% if options.forward_all_logs -%}
forward_all_logs = True
{% endif -%}
{% if options.tenant_log_targets -%}
tenant_log_targets = {{ options.tenant_log_targets }}
user_log_facility = {{ options.user_log_facility }}
{% endif -%}
{% if options.admin_log_targets or options.tenant_log_targets -%}
log_protocol = {{ options.log_protocol }}
{% if options.log_retry_count is not none -%}
log_retry_count = {{ options.log_retry_count }}
{% endif -%}
{% if options.log_retry_interval is not none -%}
log_retry_interval = {{ options.log_retry_interval }}
{% endif -%}
{% endif -%}
{% if options.disable_local_log_storage -%}
disable_local_log_storage = True
{% endif -%}
